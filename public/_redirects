# RSS feed aliases. Auto-discovery works off the <link rel="alternate"> tag in
# the page head regardless of filename, but some readers probe common paths
# when handed a bare domain. These cover the usual guesses.
/feed.xml   /rss.xml   301
/atom.xml   /rss.xml   301
/feed       /rss.xml   301
/rss        /rss.xml   301

# Layout rework (2026-06): the post archive moved from / to /posts, pagination
# from /page/N to /posts/page/N, and the old /search route folded into /posts.
/search     /posts/             301
/page/*     /posts/page/:splat  301
