{
  "name": "log-comments",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Comments backend for log.fisher.sh - a Cloudflare Worker + D1. Bluesky OAuth for identity, comments owned in D1. Deployed via nottingham-cloud make targets.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply log-comments --local",
    "migrate:remote": "wrangler d1 migrations apply log-comments --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.84.0"
  }
}
