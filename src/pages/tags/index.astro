---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
for (const post of posts) {
    for (const tag of post.data.tags) {
        tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<!doctype html>
<html lang="en">
    <head><BaseHead title={`Tags · ${SITE_TITLE}`} description="All tags" /></head>
    <body>
        <Header />
        <main>
            <h1>Tags</h1>
            <ul class="tag-list">
                {tags.map(([tag, count]) => (
                    <li><a href={`/tags/${tag}/`}>{tag}</a> <span class="count">({count})</span></li>
                ))}
            </ul>
        </main>
        <Footer />
        <style>
            main { width: 720px; max-width: 100%; padding: 0 1em; }
            .tag-list { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.75em; }
            .tag-list li a { padding: 0.4em 0.9em; border-radius: 999px; background: rgb(var(--gray-light)); text-decoration: none; color: rgb(var(--gray-dark)); }
            .tag-list li a:hover { background: rgb(var(--accent)); color: white; }
            .count { color: rgb(var(--gray)); font-size: 0.85em; }
        </style>
    </body>
</html>
