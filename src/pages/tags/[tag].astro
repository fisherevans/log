---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
    const posts = await getCollection('posts', ({ data }) => !data.draft);
    const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
    return tags.map((tag) => ({
        params: { tag },
        props: {
            tag,
            posts: posts.filter((p) => p.data.tags.includes(tag))
                .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
        },
    }));
}

const { tag, posts } = Astro.props;
---
<!doctype html>
<html lang="en">
    <head><BaseHead title={`tag: ${tag} · ${SITE_TITLE}`} description={`posts tagged ${tag}`} /></head>
    <body>
        <Header />
        <main>
            <p class="back"><a href="/tags/">← all tags</a></p>
            <h1><span class="hash">#</span>{tag}</h1>
            <ul class="post-list">
                {posts.map((post) => (
                    <li>
                        <a class="title-link" href={`/posts/${post.id}/`}>{post.data.title}</a>
                        <span class="date"><FormattedDate date={post.data.date} /></span>
                    </li>
                ))}
            </ul>
        </main>
        <Footer />
        <style>
            .back { font-size: 0.9em; margin-bottom: 1.5em; }
            .hash { color: var(--accent); font-weight: 800; }
            .post-list { list-style: none; padding: 0; margin: 0; }
            .post-list li {
                padding: 0.85em 0;
                border-bottom: 1px solid var(--rule);
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                gap: 1em;
                flex-wrap: wrap;
            }
            .post-list li::before { content: none; }
            .title-link { color: var(--fg); }
            .date {
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.78em;
                color: var(--muted);
                letter-spacing: 0.03em;
                white-space: nowrap;
            }
        </style>
    </body>
</html>
