---
import type { GetStaticPaths, PaginateFunction } from 'astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostList from '../../components/PostList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// Pages 2..N of the "older posts" list. Page 1 lives on the index (below the
// featured latest post), so the featured post is excluded here and page 1 is
// dropped from the generated routes.
export const getStaticPaths: GetStaticPaths = async ({ paginate }: { paginate: PaginateFunction }) => {
    const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
        (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
    );
    const older = posts.slice(1);
    return paginate(older, { pageSize: 25 }).filter((p) => p.params.page !== '1' && p.params.page !== undefined);
};

const { page } = Astro.props;
const prevHref = page.currentPage === 2 ? '/' : `/page/${page.currentPage - 1}`;
const nextHref = page.currentPage < page.lastPage ? `/page/${page.currentPage + 1}` : null;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`${SITE_TITLE} - older posts (page ${page.currentPage})`} description={SITE_DESCRIPTION} />
        <style>
            .section-label {
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.72rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--muted);
                margin: 0 0 1.1em;
            }
            .pagination {
                margin-top: 2em;
                display: flex;
                justify-content: space-between;
                gap: 1em;
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.85rem;
            }
            .pagination .spacer {
                margin-left: auto;
            }
            /* End-of-archive cap on the final page so the list doesn't stop dead. */
            .list-end {
                margin-top: 2.2em;
                padding-top: 1.5em;
                border-top: 1px solid var(--rule);
                text-align: center;
                color: var(--muted);
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.78rem;
                letter-spacing: 0.06em;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <p class="section-label">Older posts &middot; page {page.currentPage}</p>
            <PostList posts={page.data} />
            <div class="pagination">
                <a href={prevHref}>&larr; Newer</a>
                {nextHref && <a class="spacer" href={nextHref}>Older &rarr;</a>}
            </div>
            {!nextHref && <p class="list-end">That&rsquo;s everything &middot; no more posts.</p>}
        </main>
        <Footer />
    </body>
</html>
