---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { FRIENDS, displayUrl } from '../data/friends';
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Friends · ${SITE_TITLE}`} description="Friends' blogs worth following." />
        <style>
            .intro {
                font-size: 1.05em;
                color: var(--fg);
                max-width: 36em;
                margin: 0 0 0.8rem;
            }
            .intro-note {
                font-size: 1.05em;
                color: var(--muted);
                font-style: italic;
                max-width: 36em;
                margin: 0 0 2.4rem;
            }

            /* Blogroll: full-width rows, distinct from the tag-page card grid.
               No avatars - just name, mono URL, and a one-liner. The whole row is
               one link. */
            .roll {
                list-style: none;
                margin: 0;
                padding: 0;
                border-top: 1px solid var(--rule);
            }
            .roll li { margin: 0; padding: 0; }
            .roll li::before { content: none; }
            .friend {
                display: block;
                padding: 1.35em 1.1em;
                /* font-weight reset: the row is an <a> (link weight 600); keep the
                   body text normal, only the name is bold. */
                font-weight: 400;
                color: var(--fg);
                text-decoration: none;
                border-bottom: 1px solid var(--rule);
                border-left: 2px solid transparent;
                transition:
                    border-left-color 0.15s,
                    background 0.15s,
                    padding-left 0.15s;
            }
            /* Override the global a:hover orange wash - on a row we just want the
               accent bar + subtle surface. */
            .friend:hover {
                border-left-color: var(--accent);
                border-bottom-color: var(--rule);
                background: var(--code-bg);
                padding-left: 1.4em;
                box-shadow: none;
                color: var(--fg);
            }
            .friend .top {
                display: flex;
                align-items: baseline;
                gap: 0.7em;
                flex-wrap: wrap;
            }
            .friend .name {
                font-family: 'Marauder', serif;
                font-weight: 700;
                font-variation-settings: 'opsz' 20;
                font-size: 1.45rem;
                color: var(--fg);
            }
            .friend:hover .name { color: var(--accent); }
            .friend .url {
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.72rem;
                color: var(--muted);
            }
            .friend .arrow {
                margin-left: auto;
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.78rem;
                color: var(--accent);
                opacity: 0;
                transition: opacity 0.15s;
            }
            .friend:hover .arrow { opacity: 1; }
            .friend .desc {
                display: block;
                margin: 0.4em 0 0;
                color: var(--muted);
                font-size: 0.95em;
                max-width: 42em;
            }
            @media (max-width: 600px) {
                .friend .arrow { display: none; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h1>Friends</h1>
            <p class="intro">
                These are my friends&rsquo; blogs! Consider following them if you&rsquo;ve enjoyed
                mine.
            </p>
            <p class="intro-note">I hope this page needs pagination at some point&hellip;</p>
            <ul class="roll">
                {
                    FRIENDS.map((f) => (
                        <li>
                            <a class="friend" href={f.url}>
                                <span class="top">
                                    <span class="name">{f.name}</span>
                                    <span class="url">{displayUrl(f.url)}</span>
                                    <span class="arrow">visit &rarr;</span>
                                </span>
                                {f.description && <span class="desc">{f.description}</span>}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </main>
        <Footer />
    </body>
</html>
