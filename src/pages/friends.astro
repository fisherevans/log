---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { FRIENDS, displayUrl } from '../data/friends';
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Friends · ${SITE_TITLE}`} description="Friends' blogs worth following." />
        <style>
            .intro {
                font-size: 1.05em;
                color: var(--fg);
                max-width: 36em;
                margin: 0 0 2.4rem;
            }
            .intro em { color: var(--muted); }

            /* Blogroll: full-width rows, distinct from the tag-page card grid.
               No avatars - just name, mono URL, and a one-liner. */
            .roll {
                list-style: none;
                margin: 0;
                padding: 0;
                border-top: 1px solid var(--rule);
            }
            .roll li {
                margin: 0;
                padding: 1.35em 1.1em;
                border-bottom: 1px solid var(--rule);
                border-left: 2px solid transparent;
                position: relative;
                transition:
                    border-left-color 0.15s,
                    background 0.15s,
                    padding-left 0.15s;
            }
            .roll li::before { content: none; }
            .roll li:hover {
                border-left-color: var(--accent);
                background: var(--code-bg);
                padding-left: 1.4em;
            }
            .roll .top {
                display: flex;
                align-items: baseline;
                gap: 0.7em;
                flex-wrap: wrap;
            }
            .roll .name {
                font-family: 'Marauder', serif;
                font-weight: 700;
                font-variation-settings: 'opsz' 20;
                font-size: 1.45rem;
                color: var(--fg);
                border-bottom: none;
            }
            .roll li:hover .name { color: var(--accent); }
            .roll .name:hover {
                color: var(--hover);
                background-color: var(--hover-bg);
                box-shadow: 0.15em 0 0 var(--hover-bg), -0.15em 0 0 var(--hover-bg);
            }
            .roll .url {
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.72rem;
                color: var(--muted);
            }
            .roll .arrow {
                margin-left: auto;
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.78rem;
                color: var(--accent);
                opacity: 0;
                transition: opacity 0.15s;
            }
            .roll li:hover .arrow { opacity: 1; }
            .roll .desc {
                margin: 0.4em 0 0;
                color: var(--muted);
                font-size: 0.95em;
                max-width: 42em;
            }
            @media (max-width: 600px) {
                .roll .arrow { display: none; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h1>Friends</h1>
            <p class="intro">
                These are my friends&rsquo; blogs! Consider following them if you&rsquo;ve enjoyed
                mine. <em>I hope this page needs pagination at some point&hellip;</em>
            </p>
            <ul class="roll">
                {
                    FRIENDS.map((f) => (
                        <li>
                            <div class="top">
                                <a class="name" href={f.url}>{f.name}</a>
                                <span class="url">{displayUrl(f.url)}</span>
                                <span class="arrow">visit &rarr;</span>
                            </div>
                            {f.description && <p class="desc">{f.description}</p>}
                        </li>
                    ))
                }
            </ul>
        </main>
        <Footer />
    </body>
</html>
