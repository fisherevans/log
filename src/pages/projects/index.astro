---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = await getCollection('posts', ({ data }) => !data.draft && data.project);
const projectCounts = new Map<string, number>();
for (const post of posts) {
    const p = post.data.project!;
    projectCounts.set(p, (projectCounts.get(p) ?? 0) + 1);
}
const projects = [...projectCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<!doctype html>
<html lang="en">
    <head><BaseHead title={`projects · ${SITE_TITLE}`} description="all projects" /></head>
    <body>
        <Header />
        <main>
            <h1>projects</h1>
            <ul class="project-list">
                {projects.map(([project, count]) => (
                    <li>
                        <a href={`/projects/${project}/`}>{project}</a>
                        <span class="count">{count}</span>
                    </li>
                ))}
            </ul>
        </main>
        <Footer />
        <style>
            .project-list { list-style: none; padding: 0; margin: 0; }
            .project-list li {
                padding: 0.65em 0;
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                gap: 1em;
                border-bottom: 1px solid var(--rule);
            }
            .project-list li::before { content: none; }
            .count {
                color: var(--muted);
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.78em;
            }
        </style>
    </body>
</html>
