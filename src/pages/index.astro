---
import { getCollection, render } from 'astro:content';
import { hasMoreThanExcerpt, postHref } from '../lib/posts';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostList from '../components/PostList.astro';
import { SITE_DESCRIPTION, SITE_TITLE, BLUESKY_PROFILE_URL, BLUESKY_HANDLE } from '../consts';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const [featured, ...older] = posts;
const { Content } = await render(featured);
const PAGE_SIZE = 25;
const olderFirstPage = older.slice(0, PAGE_SIZE);
const hasMoreOlder = older.length > PAGE_SIZE;
const featuredHasMore = hasMoreThanExcerpt(featured);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            .intro {
                margin: 0 0 2.5rem;
                color: var(--fg);
                font-size: 1.05em;
                line-height: 1.6;
                text-align: center;
            }
            .intro .linklike {
                background: none;
                border: none;
                padding: 0;
                font: inherit;
                color: var(--accent);
                cursor: pointer;
                border-bottom: 1px dotted var(--accent);
            }
            .intro .linklike:hover {
                color: var(--hover);
            }

            .section-label {
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.72rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--muted);
                margin: 0 0 1.1em;
            }

            /* Featured post sits in a subtle card so it reads as one isolated unit,
               distinct from the intro above and the older-posts list below. The
               negative inline margins pull the card out to the content edges (and
               its matching padding pulls the text back), so the card is wider than
               the column but the content stays the same width as everything else. */
            .latest {
                margin: 0 calc(-1 * var(--content-pad-x)) 2.5rem;
                padding: 1.5rem var(--content-pad-x) 1.7rem;
                background: var(--code-bg);
                border: 1px solid var(--rule);
                border-radius: 12px;
            }
            /* On narrow screens the full edge-to-edge bleed runs right up against
               (or a hair past) the viewport - pull the card in so it sits inside a
               clear gutter instead. */
            @media (max-width: 700px) {
                .latest {
                    margin-left: 0;
                    margin-right: 0;
                    padding: 1.25rem 1rem 1.4rem;
                }
            }
            .feat-title {
                margin: 0;
                line-height: 1.15;
            }
            .feat-title a {
                color: var(--fg);
                font-family: 'Marauder', serif;
                font-weight: 700;
                font-variation-settings: 'opsz' 28;
                font-size: 2rem;
            }
            .feat-title a:hover {
                color: var(--hover);
                background-color: var(--hover-bg);
                box-shadow:
                    0.15em 0 0 var(--hover-bg),
                    -0.15em 0 0 var(--hover-bg);
            }
            .feat-meta {
                margin: 0.6em 0 1.4em;
                display: flex;
                flex-wrap: wrap;
                gap: 0.5em 1em;
                align-items: baseline;
                font-size: 0.85em;
            }
            .feat-meta .date {
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.78em;
                color: var(--muted);
                letter-spacing: 0.03em;
            }
            .feat-meta .chips {
                display: flex;
                flex-wrap: wrap;
                gap: 0.35em;
            }

            /* Show only the first EXCERPT_BLOCKS (3) top-level blocks; the rest of
               the post lives behind "Continue reading". Keep n+4 in sync with
               EXCERPT_BLOCKS in lib/posts.ts. The child selectors are :global
               because <Content/>'s rendered blocks don't carry this component's
               scope attribute. */
            .excerpt > :global(:nth-child(n + 4)) {
                display: none;
            }
            .excerpt > :global(:first-child) {
                margin-top: 0;
            }
            .continue {
                display: inline-block;
                margin-top: 1.4em;
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.85rem;
                color: var(--accent);
            }
            .continue:hover {
                color: var(--hover);
            }

            .older {
                margin-top: 0.5rem;
            }
            .pagination {
                margin-top: 2em;
                display: flex;
                justify-content: flex-end;
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.85rem;
            }
            /* End-of-archive cap so the list doesn't just stop dead. */
            .list-end {
                margin-top: 2.2em;
                padding-top: 1.5em;
                border-top: 1px solid var(--rule);
                text-align: center;
                color: var(--muted);
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.78rem;
                letter-spacing: 0.06em;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <p class="intro">
                Welcome to my blog. You can <button type="button" class="linklike" data-subscribe-open
                    >subscribe</button
                > if you'd like. Or follow me, <a href={BLUESKY_PROFILE_URL}>@{BLUESKY_HANDLE}</a> on Bluesky.
            </p>

            <section class="latest">
                <p class="section-label">Latest post</p>
                <h2 class="feat-title"><a href={postHref(featured)}>{featured.data.title}</a></h2>
                <div class="feat-meta">
                    <span class="date"><FormattedDate date={featured.data.date} /></span>
                    {
                        featured.data.tags.length > 0 && (
                            <span class="chips">
                                {featured.data.tags.map((tag) => (
                                    <a class="chip" href={`/tags/${tag}/`}>
                                        {tag}
                                    </a>
                                ))}
                            </span>
                        )
                    }
                </div>
                <div class="prose excerpt">
                    <Content />
                </div>
                {
                    featuredHasMore && (
                        <a class="continue" href={`${postHref(featured)}#continue`}>
                            Continue reading &rarr;
                        </a>
                    )
                }
            </section>

            <section class="older">
                <p class="section-label">Older posts</p>
                <PostList posts={olderFirstPage} />
                {
                    hasMoreOlder ? (
                        <div class="pagination">
                            <a href="/page/2">Older posts &rarr;</a>
                        </div>
                    ) : (
                        <p class="list-end">That&rsquo;s everything &middot; no more posts.</p>
                    )
                }
            </section>
        </main>
        <Footer />
        <script>
            // Keep the excerpt from ending badly. The CSS already caps it at 3
            // top-level blocks (so lists / code blocks - which are each a single
            // top-level block - are never cut mid-way). Here we additionally trim
            // a trailing heading so the teaser never ends on a dangling header,
            // then point "Continue reading" at the first hidden block.
            const ex = document.querySelector('.excerpt');
            const cont = document.querySelector('.continue');
            if (ex) {
                const blocks = Array.from(ex.children) as HTMLElement[];
                const isHeading = (el: Element) => /^H[1-6]$/.test(el.tagName);
                let cut = Math.min(3, blocks.length);
                while (cut > 1 && isHeading(blocks[cut - 1])) cut--;
                blocks.forEach((b, i) => {
                    if (i >= cut) b.style.display = 'none';
                });
                if (cont) {
                    const base = (cont.getAttribute('href') || '').split('#')[0];
                    cont.setAttribute('href', `${base}#continue=${cut}`);
                }
            }
        </script>
    </body>
</html>
