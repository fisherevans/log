---
// Native in-page comments (issue #5). Renders an empty mount; the client script
// (src/scripts/comments.ts) fetches + renders the thread from the comments
// Worker. Only renders when the post has a stable id (what comments key on).
import { OP_DID } from '../consts';
interface Props {
    postId?: string;
}
const { postId } = Astro.props;
---

{
    postId && (
        <section class="comments" aria-label="Comments">
            <div data-comments data-post-id={postId} data-op-did={OP_DID} />
        </section>
    )
}

<style>
    .comments {
        max-width: var(--max-width);
        margin: 3em auto 0;
        padding: 2em 1em 0;
        border-top: 1px solid var(--rule);
    }
    .comments :global(.comments-heading) {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 1rem;
        letter-spacing: 0.04em;
        color: var(--muted);
        margin: 0 0 1.25em;
    }
    .comments :global(.comments-status) {
        color: var(--muted);
        font-size: 0.95rem;
    }

    /* Composer */
    .comments :global(.comment-composer) {
        display: flex;
        flex-direction: column;
        gap: 0.6em;
        margin-bottom: 2em;
    }
    .comments :global(.comment-composer-reply) {
        margin: 0.75em 0 0.25em;
        padding-left: 0.75em;
        border-left: 2px solid var(--rule);
    }
    .comments :global(.comment-input) {
        width: 100%;
        box-sizing: border-box;
        background: var(--code-bg);
        color: var(--fg);
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.6em 0.7em;
        font: inherit;
        resize: vertical;
    }
    .comments :global(.comment-input:focus-visible) {
        outline: none;
        border-color: var(--accent);
    }
    .comments :global(.comment-handle-input) {
        max-width: 22em;
    }
    .comments :global(.comment-submit) {
        align-self: flex-start;
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.85rem;
        letter-spacing: 0.03em;
        background: transparent;
        color: var(--accent);
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.45em 0.9em;
        cursor: pointer;
        transition:
            color 0.15s,
            background 0.15s,
            border-color 0.15s;
    }
    .comments :global(.comment-submit:hover),
    .comments :global(.comment-submit:focus-visible) {
        background: var(--hover-bg);
        color: var(--hover);
        border-color: var(--hover-bg);
        outline: none;
    }
    .comments :global(.comment-submit[disabled]) {
        opacity: 0.5;
        cursor: default;
    }
    .comments :global(.comment-error) {
        color: #e0683c;
        font-size: 0.9rem;
        margin: 0;
    }
    .comments :global(.comment-turnstile:empty) {
        display: none;
    }

    /* Thread */
    .comments :global(.comments-list) {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    /* Connector-line nesting: a vertical rail per reply group + an elbow stub
       from the rail to each reply's avatar, so parentage reads as a tree.
       (li.comment::before is taken by the chevron-kill, so the stub is ::after.) */
    .comments :global(.comments-replies) {
        margin-top: 0.75em;
        margin-left: 0.8em;
        padding-left: 1.5em;
        border-left: 1px solid var(--rule);
    }
    .comments :global(.comments-replies > li.comment) {
        position: relative;
    }
    .comments :global(.comments-replies > li.comment::after) {
        content: '';
        position: absolute;
        left: -1.5em;
        top: 1.55em;
        width: 1.2em;
        height: 1px;
        background: var(--rule);
    }
    .comments :global(.comment) {
        padding: 0.85em 0 0.6em;
        border-bottom: 1px solid var(--rule);
    }
    .comments :global(.comment-head) {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5em;
        margin-bottom: 0.4em;
    }
    .comments :global(.comment-avatar) {
        width: 1.4em;
        height: 1.4em;
        border-radius: 50%;
        object-fit: cover;
        background: var(--code-bg);
        border: 1px solid var(--rule);
        flex: none;
        /* Optical nudge: serif names read slightly high in their line box, so a
           geometrically-centered avatar looks low. Lift it a hair to match. */
        position: relative;
        top: -0.08em;
    }
    .comments :global(.comment-author) {
        font-weight: 600;
        color: var(--fg);
    }
    .comments :global(.comment-handle),
    .comments :global(.comment-time) {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.78rem;
        color: var(--muted);
    }
    .comments :global(.comment-handle) {
        border-bottom: none;
    }
    .comments :global(.comment-time) {
        margin-left: auto;
    }
    .comments :global(.comment-body) {
        color: var(--fg);
        line-height: 1.5;
        overflow-wrap: anywhere;
    }
    /* Reply is the only bottom action now (the "..." menu moved up to the head),
       so the row is just a right-floated icon with a tight top gap. */
    .comments :global(.comment-actions) {
        display: flex;
        gap: 0.6em;
        margin-top: 0.1em;
        justify-content: flex-end;
    }
    .comments :global(.comment-link) {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.78rem;
        color: var(--muted);
    }
    .comments :global(.comment-link:hover) {
        color: var(--accent);
    }

    /* --- UX iteration ------------------------------------------------------ */

    /* The structural comment <li> is a layout container, not a list item -
       strip the global chevron + indent from it. Markdown lists *inside*
       .comment-body keep the site chevron (handled in the markdown block). */
    .comments :global(li.comment) {
        padding-left: 0;
    }
    .comments :global(li.comment::before) {
        content: none;
    }

    /* Sans-serif for the "machine" meta (handle, time, actions) - contrast
       against the serif author names + bodies. */
    .comments :global(.comment-handle),
    .comments :global(.comment-time),
    .comments :global(.comment-link) {
        font-family: ui-sans-serif, system-ui, sans-serif;
        letter-spacing: 0;
    }

    /* OP / author: accent the name + a subtle outline pill. */
    .comments :global(.comment-op .comment-author) {
        color: var(--accent);
    }
    .comments :global(.comment-op-badge) {
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.6rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        border: 1px solid var(--accent);
        border-radius: 999px;
        padding: 0.05em 0.45em;
        margin-left: 0.15em;
        opacity: 0.85;
    }

    /* Reply as an icon, pushed to the right of the actions row. */
    .comments :global(.comment-actions) {
        align-items: center;
    }
    .comments :global(.comment-action-reply) {
        margin-left: auto;
    }
    .comments :global(.comment-icon) {
        display: inline-flex;
        vertical-align: -0.15em;
    }
    .comments :global(.comment-icon svg) {
        width: 1.05em;
        height: 1.05em;
    }

    /* --- markdown bodies --------------------------------------------------- */

    /* Tight vertical rhythm - comments are short. First/last child flush so the
       body sits where a plain string used to. */
    .comments :global(.comment-body > :first-child) {
        margin-top: 0;
    }
    .comments :global(.comment-body > :last-child) {
        margin-bottom: 0;
    }
    .comments :global(.comment-body p) {
        margin: 0 0 0.6em;
    }
    /* Markdown lists use plain bullets (a white disc / decimal), NOT the site's
       accent chevron - that stylized marker is for blog-post prose, not comments.
       Re-enable native markers (global.css sets `ul,ol { list-style: none }`) and
       kill the global `li::before` chevron + its indent. */
    .comments :global(.comment-body ul),
    .comments :global(.comment-body ol) {
        margin: 0.4em 0;
        padding-left: 1.5em;
    }
    /* A paragraph immediately before a list (e.g. "A few points:") sits closer
       so the gap above the list matches the gap below it. */
    .comments :global(.comment-body p:has(+ ul)),
    .comments :global(.comment-body p:has(+ ol)) {
        margin-bottom: 0.4em;
    }
    .comments :global(.comment-body ul) {
        list-style: disc outside;
    }
    .comments :global(.comment-body ol) {
        list-style: decimal outside;
    }
    .comments :global(.comment-body li) {
        padding-left: 0;
        margin: 0.08em 0;
    }
    .comments :global(.comment-body li::before) {
        content: none;
    }
    .comments :global(.comment-body li::marker) {
        color: var(--fg);
    }
    .comments :global(.comment-body code) {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.75em;
        background: var(--code-bg);
        border: 1px solid var(--rule);
        border-radius: 4px;
        padding: 0.05em 0.35em;
    }
    .comments :global(.comment-body pre) {
        background: var(--code-bg);
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.7em 0.8em;
        overflow-x: auto;
        margin: 0 0 0.6em;
    }
    .comments :global(.comment-body pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.85em;
    }
    .comments :global(.comment-body blockquote) {
        margin: 0 0 0.6em;
        padding-left: 0.9em;
        border-left: 2px solid var(--rule);
        color: var(--muted);
    }
    .comments :global(.comment-deleted) {
        color: var(--muted);
    }

    /* Links: never look like a bare hyperlink (anti-phishing). Dotted underline
       + an external-link glyph mark them as "click to see destination". */
    .comments :global(.comment-mdlink) {
        color: var(--accent);
        text-decoration: underline dotted;
        text-underline-offset: 2px;
        cursor: pointer;
    }
    .comments :global(.comment-linkicon) {
        display: inline-flex;
        vertical-align: -0.05em;
        margin-left: 0.1em;
        opacity: 0.7;
    }

    /* --- composer: write/preview tabs -------------------------------------- */

    .comments :global(.comment-tabs) {
        display: flex;
        align-items: center;
        gap: 0.25em;
    }
    .comments :global(.comment-tab) {
        background: none;
        border: none;
        padding: 0.2em 0.1em;
        margin-right: 0.6em;
        cursor: pointer;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.8rem;
        color: var(--muted);
        border-bottom: 2px solid transparent;
    }
    .comments :global(.comment-tab-on) {
        color: var(--fg);
        border-bottom-color: var(--accent);
    }
    .comments :global(.comment-format-help) {
        margin-left: auto;
        font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .comments :global(.comment-preview) {
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.6em 0.7em;
        min-height: 3.2em;
        background: var(--code-bg);
    }

    /* --- modals (link confirm + syntax help) ------------------------------- */

    .comments :global(.comment-modal-back),
    :global(.comment-modal-back) {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5em;
        background: rgba(0, 0, 0, 0.55);
    }
    :global(.comment-modal) {
        background: var(--bg);
        color: var(--fg);
        border: 1px solid var(--rule);
        border-radius: 10px;
        padding: 1.4em 1.5em;
        max-width: 30em;
        width: 100%;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    }
    :global(.comment-modal h3) {
        margin: 0 0 0.6em;
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.95rem;
        letter-spacing: 0.03em;
    }
    :global(.comment-modal-note) {
        color: var(--muted);
        font-size: 0.9rem;
        margin: 0.6em 0;
        line-height: 1.5;
    }
    :global(.comment-modal-url) {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.85rem;
        word-break: break-all;
        background: var(--code-bg);
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.6em 0.7em;
        margin: 0.4em 0 1em;
    }
    :global(.comment-modal-row) {
        display: flex;
        gap: 0.6em;
    }
    :global(.comment-modal-btn) {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.82rem;
        background: transparent;
        color: var(--accent);
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.45em 0.9em;
        cursor: pointer;
    }
    :global(.comment-modal-btn:hover) {
        background: var(--hover-bg);
        color: var(--hover);
        border-color: var(--hover-bg);
    }
    :global(.comment-modal-btn-ghost) {
        color: var(--muted);
    }
    :global(.comment-syntax) {
        list-style: none;
        margin: 0 0 0.4em;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.45em;
        font-size: 0.92rem;
    }
    :global(.comment-syntax code) {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.85em;
        background: var(--code-bg);
        border: 1px solid var(--rule);
        border-radius: 4px;
        padding: 0.05em 0.35em;
    }

    /* --- "..." actions menu (#13) ------------------------------------------ */

    .comments :global(.comment-menu) {
        position: relative;
        display: inline-flex;
    }
    .comments :global(.comment-menu-btn) {
        display: inline-flex;
        align-items: center;
    }
    .comments :global(.comment-menu-pop[hidden]) {
        display: none;
    }
    .comments :global(.comment-menu-pop) {
        position: absolute;
        top: calc(100% + 0.35em);
        right: 0;
        left: auto;
        z-index: 20;
        min-width: 11em;
        display: flex;
        flex-direction: column;
        padding: 0.3em;
        background: var(--bg);
        border: 1px solid var(--rule);
        border-radius: 8px;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
    }
    .comments :global(.comment-menu-item) {
        text-align: left;
        background: none;
        border: none;
        border-radius: 5px;
        padding: 0.45em 0.6em;
        cursor: pointer;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.85rem;
        color: var(--fg);
    }
    .comments :global(.comment-menu-item:hover) {
        background: var(--hover-bg);
        color: var(--hover);
    }
    .comments :global(.comment-menu-danger) {
        color: #e0683c;
    }
    .comments :global(.comment-menu-danger:hover) {
        background: rgba(224, 104, 60, 0.14);
        color: #e0683c;
    }

    /* Permalink / new-comment highlight (#16): a slow, single accent wash on the
       landed comment - long enough to notice, no repeat flashing. Matches the
       post "Continue reading" highlight. */
    .comments :global(.comment-flash) {
        animation: comment-flash 3.2s ease-out;
    }
    @keyframes comment-flash {
        0% {
            background: color-mix(in srgb, var(--accent) 18%, transparent);
        }
        100% {
            background: transparent;
        }
    }

    /* Transient copy/permalink feedback. */
    :global(.comment-toast) {
        position: fixed;
        left: 50%;
        bottom: 2em;
        transform: translate(-50%, 0.6em);
        z-index: 1100;
        padding: 0.55em 1em;
        background: var(--fg);
        color: var(--bg);
        border-radius: 999px;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.82rem;
        opacity: 0;
        transition:
            opacity 0.2s,
            transform 0.2s;
        pointer-events: none;
    }
    :global(.comment-toast-show) {
        opacity: 0.95;
        transform: translate(-50%, 0);
    }

    /* --- admin moderation (#14) -------------------------------------------- */

    .comments :global(.comments-header) {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1em;
    }
    .comments :global(.comment-admin-link) {
        font-family: ui-sans-serif, system-ui, sans-serif;
        color: var(--accent);
    }
    :global(.comment-admin-toggles) {
        display: flex;
        flex-direction: column;
        gap: 0.7em;
        margin: 0.8em 0 1.2em;
    }
    :global(.comment-admin-toggle) {
        display: flex;
        align-items: center;
        gap: 0.6em;
        font-size: 0.95rem;
        cursor: pointer;
    }
    :global(.comment-admin-toggle input) {
        width: 1.05em;
        height: 1.05em;
        accent-color: var(--accent);
        cursor: pointer;
    }

    /* --- edits (#15) ------------------------------------------------------- */

    /* "edited" marker: a quiet magnitude indicator, not a link to old text. */
    .comments :global(.comment-edited) {
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.72rem;
        color: var(--muted);
        font-style: italic;
        margin-left: 0.5em;
        cursor: help;
    }
    .comments :global(.comment-editor) {
        margin: 0.4em 0 0.2em;
    }
    .comments :global(.comment-editor-actions) {
        display: flex;
        align-items: center;
        gap: 1em;
    }

    /* --- sign-in button (#19): Bluesky logo + sans-serif ------------------- */

    .comments :global(.comment-signin-btn) {
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        font-family: ui-sans-serif, system-ui, sans-serif;
        letter-spacing: 0;
        font-size: 0.9rem;
    }
    .comments :global(.comment-signin-btn .comment-icon svg) {
        width: 1.1em;
        height: 1.1em;
    }

    /* --- threading: load-more, drill-in, breadcrumb (#12) ------------------ */

    /* These rows are <li> in .comments-list but not .comment, so kill the global
       chevron + indent the same way. */
    .comments :global(.comments-loadmore-row),
    .comments :global(.comments-drillin-row) {
        padding-left: 0;
        list-style: none;
    }
    .comments :global(.comments-loadmore-row::before),
    .comments :global(.comments-drillin-row::before) {
        content: none;
    }
    .comments :global(.comments-loadmore-row) {
        margin-top: 1em;
    }
    .comments :global(.comment-loadmore) {
        font-family: ui-sans-serif, system-ui, sans-serif;
        letter-spacing: 0;
    }
    .comments :global(.comment-drillin) {
        font-family: ui-sans-serif, system-ui, sans-serif;
        color: var(--accent);
        padding: 0.3em 0;
    }
    .comments :global(.comments-breadcrumb) {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.4em;
        margin-bottom: 1.5em;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.85rem;
    }
    .comments :global(.comments-crumb-sep) {
        color: var(--muted);
    }
    .comments :global(.comments-crumb-current) {
        color: var(--fg);
        font-weight: 600;
    }

    /* Drilled-in focus: the comment you zoomed into stands out from its replies. */
    .comments :global(.comment-focused) {
        background: color-mix(in srgb, var(--accent) 7%, transparent);
        border-left: 2px solid var(--accent);
        border-radius: 0 6px 6px 0;
        padding-left: 0.8em;
        margin-left: -0.8em;
    }

    /* Composer / editor action row: submit + (dismiss) together at the bottom. */
    .comments :global(.comment-composer-actions),
    .comments :global(.comment-editor-actions) {
        display: flex;
        align-items: center;
        gap: 1em;
    }

    /* Share-link fallback modal: the URL in a selectable field. */
    :global(.comment-modal-urlinput) {
        width: 100%;
        box-sizing: border-box;
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.85rem;
        color: var(--fg);
        background: var(--code-bg);
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.6em 0.7em;
        margin: 0.4em 0 1em;
    }
</style>

<script>
    import { initComments } from '../scripts/comments';
    initComments();
</script>
