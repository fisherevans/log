---
// Subscribe CTA (issue #7), compact for the site footer. A native email form
// posting to the comments Worker (emails land in D1, sent manually - no
// automation), plus the follow options. Deliberately subtle: this is footer
// furniture, not blog-post content.
import { COMMENTS_API_URL, BLUESKY_PROFILE_URL, BLUESKY_HANDLE } from '../consts';
---

<section class="subscribe" aria-label="Subscribe">
    <p class="subscribe-lede">Wanna get an email when I post some of my stuff?</p>
    <form data-subscribe class="subscribe-form" data-api={COMMENTS_API_URL}>
        <div class="subscribe-row">
            <input type="email" name="email" placeholder="you@example.com" required aria-label="Email address" />
            <button type="submit">Subscribe</button>
        </div>
        <div data-subscribe-turnstile class="subscribe-turnstile"></div>
        <p data-subscribe-status class="subscribe-status" role="status" aria-live="polite"></p>
    </form>
    <p class="subscribe-alt">
        Or follow <a href={BLUESKY_PROFILE_URL} rel="me">@{BLUESKY_HANDLE} on Bluesky</a>, or grab the <a href="/rss.xml">RSS feed</a>.
    </p>
</section>

<style>
    .subscribe {
        font-size: 0.85rem;
    }
    .subscribe-lede {
        margin: 0 0 0.7em;
        color: var(--muted);
    }
    .subscribe-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4em;
        max-width: 30em;
    }
    .subscribe-form input[type='email'] {
        flex: 1 1 14em;
        background: var(--code-bg);
        color: var(--fg);
        border: 1px solid var(--rule);
        border-radius: 5px;
        padding: 0.45em 0.6em;
        font: inherit;
    }
    .subscribe-form input[type='email']:focus-visible {
        outline: none;
        border-color: var(--accent);
    }
    .subscribe-form button {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.78rem;
        letter-spacing: 0.02em;
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--rule);
        border-radius: 5px;
        padding: 0.45em 0.85em;
        cursor: pointer;
        transition:
            color 0.15s,
            border-color 0.15s;
    }
    .subscribe-form button:hover,
    .subscribe-form button:focus-visible {
        color: var(--accent);
        border-color: var(--accent);
        outline: none;
    }
    .subscribe-form button:disabled {
        opacity: 0.5;
        cursor: default;
    }
    .subscribe-turnstile:empty {
        display: none;
    }
    .subscribe-turnstile {
        margin-top: 0.5em;
    }
    .subscribe-status:empty {
        display: none;
    }
    .subscribe-status {
        margin: 0.5em 0 0;
        color: var(--muted);
    }
    .subscribe-alt {
        margin: 0.7em 0 0;
        color: var(--muted);
    }
</style>

<script>
    import { initSubscribe } from '../scripts/subscribe';
    initSubscribe();
</script>
