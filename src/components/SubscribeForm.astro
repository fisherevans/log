---
// Subscribe CTA (issue #7). A native email form posting to the comments Worker
// (emails land in D1, sent manually - no automation), plus the follow options.
//
// Progressive, fixed-height flow so the layout never jumps: the slot starts as
// the email row, swaps to the Turnstile human-check after Subscribe is clicked
// (the check is only loaded then - no widget sitting there upfront), then swaps
// to the confirmation. All three stages share one reserved-height slot.
import { COMMENTS_API_URL, BLUESKY_PROFILE_URL, BLUESKY_HANDLE } from '../consts';

interface Props {
    // Override the lede copy (the /follow page sets its own).
    lede?: string;
    // Drop the built-in lede entirely (the /follow page renders the descriptive
    // text as a normal page paragraph so the sizes match the rest of the page).
    hideLede?: boolean;
    // Show the "Or follow on Bluesky / RSS" line. Off on /follow, which
    // surfaces those as their own cards.
    showAlt?: boolean;
}
const {
    lede = 'Wanna get an email when I post some of my stuff?',
    hideLede = false,
    showAlt = true,
} = Astro.props;
---

<section class="subscribe" aria-label="Subscribe">
    {!hideLede && <p class="subscribe-lede">{lede}</p>}
    <form data-subscribe class="subscribe-form" data-api={COMMENTS_API_URL}>
        <div class="subscribe-slot">
            <div class="subscribe-row" data-subscribe-stage="email">
                <input type="email" name="email" placeholder="you@example.com" required aria-label="Email address" />
                <button type="submit">Subscribe</button>
            </div>
            <div data-subscribe-turnstile class="subscribe-turnstile" data-subscribe-stage="check" hidden></div>
            <p class="subscribe-done" data-subscribe-stage="done" hidden>You&rsquo;re subscribed. Talk soon.</p>
        </div>
        <p data-subscribe-status class="subscribe-status" role="status" aria-live="polite"></p>
    </form>
    {
        showAlt && (
            <p class="subscribe-alt">
                Or follow{' '}
                <a href={BLUESKY_PROFILE_URL} rel="me">
                    @{BLUESKY_HANDLE} on Bluesky
                </a>
                , or grab the{' '}
                <a href="/rss.xml" data-link-preview data-link-preview-label="RSS feed">
                    RSS feed
                </a>
                .
            </p>
        )
    }
</section>

<style>
    .subscribe {
        font-size: 0.85rem;
    }
    .subscribe-lede {
        margin: 0 0 0.7em;
        color: var(--muted);
    }

    /* One reserved-height slot the three stages swap through, so nothing below
       shifts when the Turnstile (tallest stage) appears or the confirmation
       replaces it. Height is sized to the Turnstile widget (~65px). */
    .subscribe-slot {
        display: flex;
        align-items: center;
        min-height: 4.25rem;
    }
    .subscribe-slot > [data-subscribe-stage] {
        width: 100%;
    }
    .subscribe-slot > [hidden] {
        display: none !important;
    }

    .subscribe-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4em;
        max-width: 30em;
    }
    .subscribe-form input[type='email'] {
        flex: 1 1 14em;
        background: var(--code-bg);
        color: var(--fg);
        border: 1px solid var(--rule);
        border-radius: 5px;
        padding: 0.45em 0.6em;
        font: inherit;
    }
    .subscribe-form input[type='email']:focus-visible {
        outline: none;
        border-color: var(--accent);
    }
    .subscribe-form button {
        font-family: 'DraftingMono', ui-monospace, monospace;
        font-size: 0.78rem;
        letter-spacing: 0.02em;
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--rule);
        border-radius: 5px;
        padding: 0.45em 0.85em;
        cursor: pointer;
        transition:
            color 0.15s,
            border-color 0.15s;
    }
    .subscribe-form button:hover,
    .subscribe-form button:focus-visible {
        color: var(--accent);
        border-color: var(--accent);
        outline: none;
    }
    .subscribe-form button:disabled {
        opacity: 0.5;
        cursor: default;
    }
    .subscribe-done {
        margin: 0;
        color: var(--accent);
    }

    /* Reserve a line for status text (errors) so it doesn't shove the layout when
       it appears. */
    .subscribe-status {
        margin: 0.5em 0 0;
        min-height: 1.2em;
        color: var(--muted);
    }
    .subscribe-alt {
        margin: 0.7em 0 0;
        color: var(--muted);
    }
</style>

<script>
    import { initSubscribe } from '../scripts/subscribe';
    initSubscribe();
</script>
