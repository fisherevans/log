---
const today = new Date();
---

<footer>
    <div class="inner">
        <span>&copy; {today.getFullYear()} fisher evans</span>
        <span class="links">
            <a href="https://fisher.sh">fisher.sh</a>
            <a href="https://github.com/fisherevans">github</a>
            <a href="/rss.xml">rss</a>
        </span>
    </div>
</footer>
<style>
    footer {
        border-top: 1px solid var(--rule);
        margin-top: 4em;
        color: var(--muted);
    }
    .inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1.5em 1em;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1em;
        font-size: 0.85rem;
        flex-wrap: wrap;
    }
    .links {
        display: flex;
        gap: 1em;
    }
</style>
