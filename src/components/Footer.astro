---
import { SOCIAL_LINKS } from '../consts';
import SubscribeForm from './SubscribeForm.astro';
const today = new Date();
---

<footer>
    <div class="inner">
        <SubscribeForm />
        <div class="meta">
            <span>&copy; {today.getFullYear()} fisher evans</span>
            <span class="links">
                {SOCIAL_LINKS.map((link) => <a href={link.href}>{link.label}</a>)}
            </span>
        </div>
    </div>
</footer>
<style>
    footer {
        border-top: 1px solid var(--rule);
        margin-top: 4em;
        color: var(--muted);
    }
    .inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1.8em 1em;
    }
    .meta {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1em;
        margin-top: 1.6em;
        padding-top: 1.2em;
        border-top: 1px solid var(--rule);
        font-size: 0.85rem;
        flex-wrap: wrap;
    }
    .links {
        display: flex;
        gap: 1em;
    }
</style>
