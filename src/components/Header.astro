---
import HeaderLink from './HeaderLink.astro';

// Top-level nav. Desktop shows the full inline link row; below 560px it
// collapses to a "current-page chevron" dropdown (native <details>) so the
// five items never crowd a phone. fisher.sh is intentionally not in the bar -
// it's referenced inline on the landing and in the footer.
const NAV = [
    { href: '/', label: 'home' },
    { href: '/posts/', label: 'posts' },
    { href: '/tags/', label: 'tags' },
    { href: '/friends/', label: 'friends' },
    { href: '/follow/', label: 'follow' },
];

// Current page label for the collapsed dropdown's summary.
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const firstSeg = '/' + (pathname.match(/[^\/]+/g)?.[0] ?? '');
const current = NAV.find((n) => n.href === pathname || n.href === firstSeg) ?? NAV[0];
---

<header>
    <nav>
        <a href="/" class="brand">log<span class="brand-suffix">.fisher.sh</span></a>
        <div class="nav-links">
            {NAV.map((n) => <HeaderLink href={n.href}>{n.label}</HeaderLink>)}
        </div>
        <details class="navmenu">
            <summary>
                <span class="cur">{current.label}</span>
                <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="menu">
                {NAV.map((n) => <HeaderLink href={n.href}>{n.label}</HeaderLink>)}
            </div>
        </details>
    </nav>
</header>
<style>
    header {
        border-bottom: 1px solid var(--rule);
    }
    nav {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0.85em 1em;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.25em;
        flex-wrap: wrap;
    }
    .brand {
        font-family: 'Marauder', serif;
        font-weight: 800;
        font-variation-settings: 'opsz' 14;
        font-size: 1.4rem;
        color: var(--accent);
        text-decoration: none;
        border-bottom: none;
        padding-bottom: 0;
        background-color: transparent;
        box-shadow: 0 0 0 0 transparent;
        transition:
            color 220ms ease-out,
            background-color 220ms ease-out,
            box-shadow 220ms ease-out;
    }
    .brand:hover, .brand:focus-visible {
        color: var(--hover);
        background-color: var(--hover-bg);
        box-shadow: 0.15em 0 0 var(--hover-bg), -0.15em 0 0 var(--hover-bg);
        border-bottom: none;
        outline: none;
    }
    .brand-suffix {
        color: var(--muted);
        font-weight: 600;
        transition: color 220ms ease-out;
    }
    .brand:hover .brand-suffix,
    .brand:focus-visible .brand-suffix {
        color: var(--hover);
    }
    .nav-links {
        display: flex;
        gap: 1em;
        font-size: 0.92rem;
        flex-wrap: wrap;
        align-items: baseline;
    }

    /* Collapsed dropdown: hidden until the breakpoint. */
    .navmenu {
        display: none;
        position: relative;
    }
    .navmenu summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4em;
        font-size: 0.98rem;
        color: var(--fg);
    }
    .navmenu summary::-webkit-details-marker { display: none; }
    .navmenu .chev {
        color: var(--muted);
        transition: transform 0.18s ease;
    }
    .navmenu[open] .chev { transform: rotate(180deg); }
    .navmenu .menu {
        position: absolute;
        right: 0;
        top: calc(100% + 0.55em);
        min-width: 9.5em;
        display: flex;
        flex-direction: column;
        background: var(--bg);
        border: 1px solid var(--rule);
        border-radius: 10px;
        padding: 0.4em;
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.5);
        z-index: 30;
    }
    .navmenu .menu :global(a) {
        padding: 0.55em 0.75em;
        border-radius: 7px;
        border-bottom: none;
        font-size: 0.95rem;
    }
    .navmenu .menu :global(a:hover) { box-shadow: none; }

    @media (max-width: 560px) {
        .nav-links { display: none; }
        .navmenu { display: block; }
        .brand { font-size: 1.3rem; }
        nav { padding: 0.75em 0.85em; }
    }
</style>
