---
import HeaderLink from './HeaderLink.astro';
---

<header>
    <nav>
        <a href="/" class="brand">log<span class="brand-suffix">.fisher.sh</span></a>
        <div class="nav-links">
            <HeaderLink href="/">home</HeaderLink>
            <HeaderLink href="/tags/">tags</HeaderLink>
            <HeaderLink href="/projects/">projects</HeaderLink>
            <HeaderLink href="/search/">search</HeaderLink>
            <a href="https://fisher.sh" class="cross">fisher.sh</a>
        </div>
    </nav>
</header>
<style>
    header {
        border-bottom: 1px solid var(--rule);
    }
    nav {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0.85em 1em;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.25em;
        flex-wrap: wrap;
    }
    .brand {
        font-family: 'Marauder', serif;
        font-weight: 800;
        font-variation-settings: 'opsz' 14;
        font-size: 1.4rem;
        color: var(--fg);
        text-decoration: none;
        border-bottom: none;
        padding-bottom: 0;
        background: transparent;
        box-shadow: none;
    }
    .brand:hover {
        color: var(--accent);
        background: transparent;
        box-shadow: none;
        border-bottom: none;
    }
    .brand-suffix {
        color: var(--muted);
        font-weight: 600;
    }
    .nav-links {
        display: flex;
        gap: 1em;
        font-size: 0.92rem;
        flex-wrap: wrap;
        align-items: baseline;
    }
    .nav-links a.cross {
        color: var(--muted);
        margin-left: 0.5em;
    }
    @media (max-width: 700px) {
        nav { padding: 0.65em 0.75em; gap: 0.75em; }
        .brand { font-size: 1.2rem; }
        .nav-links { font-size: 0.85rem; gap: 0.75em; }
    }
</style>
