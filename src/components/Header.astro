---
import HeaderLink from './HeaderLink.astro';

// Top-level nav. Desktop shows the full inline link row; below 560px it
// collapses to a "current-page chevron" dropdown (native <details>) so the
// five items never crowd a phone. fisher.sh is intentionally not in the bar -
// it's referenced inline on the landing and in the footer.
const NAV = [
    { href: '/', label: 'home' },
    { href: '/posts/', label: 'posts' },
    { href: '/tags/', label: 'tags' },
    { href: '/friends/', label: 'friends' },
    { href: '/follow/', label: 'follow' },
];

// Current page label for the collapsed dropdown's summary.
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const firstSeg = '/' + (pathname.match(/[^\/]+/g)?.[0] ?? '');
const current = NAV.find((n) => n.href === pathname || n.href === firstSeg) ?? NAV[0];
---

<header>
    <nav>
        <a href="/" class="brand">log<span class="brand-suffix">.fisher.sh</span></a>
        <div class="nav-right">
            <div class="nav-links">
                {NAV.map((n) => <HeaderLink href={n.href}>{n.label}</HeaderLink>)}
            </div>
            <button type="button" class="theme-toggle" aria-label="Switch to light mode" aria-pressed="false">
                <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
                <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </button>
            <details class="navmenu">
                <summary>
                    <span class="cur">{current.label}</span>
                    <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
                </summary>
                <div class="menu">
                    {NAV.map((n) => <HeaderLink href={n.href}>{n.label}</HeaderLink>)}
                </div>
            </details>
        </div>
    </nav>
    <script>
        // Theme toggle: flip <html data-theme>, persist, keep aria in sync. The
        // no-flash initial set happens earlier in BaseHead.astro.
        const btn = document.querySelector<HTMLButtonElement>('.theme-toggle');
        if (btn) {
            const root = document.documentElement;
            const sync = () => {
                const light = root.dataset.theme === 'light';
                btn.setAttribute('aria-label', light ? 'Switch to dark mode' : 'Switch to light mode');
                btn.setAttribute('aria-pressed', String(light));
            };
            sync();
            btn.addEventListener('click', () => {
                const next = root.dataset.theme === 'light' ? 'dark' : 'light';
                root.dataset.theme = next;
                try {
                    localStorage.setItem('theme', next);
                } catch (e) {}
                sync();
            });
        }
    </script>
</header>
<style>
    header {
        border-bottom: 1px solid var(--rule);
    }
    nav {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0.85em 1em;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.25em;
        flex-wrap: wrap;
    }
    .nav-right {
        display: flex;
        align-items: center;
        gap: 1em;
    }
    .theme-toggle {
        background: none;
        border: none;
        margin: 0;
        padding: 0.2em;
        color: var(--muted);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        line-height: 0;
        transition: color 0.18s ease;
    }
    .theme-toggle:hover,
    .theme-toggle:focus-visible {
        color: var(--accent);
        outline: none;
    }
    .brand {
        font-family: 'Marauder', serif;
        font-weight: 800;
        font-variation-settings: 'opsz' 14;
        font-size: 1.4rem;
        color: var(--accent);
        text-decoration: none;
        border-bottom: none;
        padding-bottom: 0;
        background-color: transparent;
        box-shadow: 0 0 0 0 transparent;
        transition:
            color 220ms ease-out,
            background-color 220ms ease-out,
            box-shadow 220ms ease-out;
    }
    .brand:hover, .brand:focus-visible {
        color: var(--hover);
        background-color: var(--hover-bg);
        box-shadow: 0.15em 0 0 var(--hover-bg), -0.15em 0 0 var(--hover-bg);
        border-bottom: none;
        outline: none;
    }
    .brand-suffix {
        color: var(--muted);
        font-weight: 600;
        transition: color 220ms ease-out;
    }
    .brand:hover .brand-suffix,
    .brand:focus-visible .brand-suffix {
        color: var(--hover);
    }
    .nav-links {
        display: flex;
        gap: 1em;
        font-size: 0.92rem;
        flex-wrap: wrap;
        align-items: baseline;
    }

    /* Collapsed dropdown: hidden until the breakpoint. */
    .navmenu {
        display: none;
        position: relative;
    }
    .navmenu summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4em;
        font-size: 0.98rem;
        color: var(--fg);
    }
    .navmenu summary::-webkit-details-marker { display: none; }
    .navmenu .chev {
        color: var(--muted);
        transition: transform 0.18s ease;
    }
    .navmenu[open] .chev { transform: rotate(180deg); }
    .navmenu .menu {
        position: absolute;
        right: 0;
        top: calc(100% + 0.55em);
        min-width: 9.5em;
        display: flex;
        flex-direction: column;
        background: var(--bg);
        border: 1px solid var(--rule);
        border-radius: 10px;
        padding: 0.4em;
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.5);
        z-index: 30;
    }
    .navmenu .menu :global(a) {
        padding: 0.55em 0.75em;
        border-radius: 7px;
        border-bottom: none;
        font-size: 0.95rem;
    }
    .navmenu .menu :global(a:hover) { box-shadow: none; }

    @media (max-width: 560px) {
        .nav-links { display: none; }
        .navmenu { display: block; }
        .brand { font-size: 1.3rem; }
        nav { padding: 0.75em 0.85em; }
    }
</style>
