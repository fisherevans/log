---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'posts'>['data'];

const { id, title, description, date, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead
            title={title}
            description={description ?? ''}
            article={{ publishedTime: date, modifiedTime: updatedDate, tags }}
        />
        <style>
            .hero {
                max-width: var(--max-width);
                margin: 0 auto 2em;
                padding: 0 1em;
            }
            .hero img {
                display: block;
                width: 100%;
                border-radius: 8px;
                border: 1px solid var(--rule);
            }
            .post-title {
                margin-bottom: 2em;
                padding-bottom: 1.5em;
                border-bottom: 1px solid var(--rule);
            }
            .post-title h1 {
                margin: 0 0 0.35em;
            }
            .post-title .date {
                font-family: 'DraftingMono', ui-monospace, monospace;
                font-size: 0.85rem;
                color: var(--muted);
                letter-spacing: 0.03em;
            }
            .post-title .last-updated {
                margin-left: 0.6em;
                font-style: italic;
            }
            .post-title .meta {
                margin-top: 0.85em;
                display: flex;
                flex-wrap: wrap;
                gap: 0.4em;
            }
            .prose > :first-child { margin-top: 0; }
        </style>
    </head>
    <body>
        <Header />
        {heroImage && (
            <div class="hero">
                <Image width={1200} height={600} src={heroImage} alt="" />
            </div>
        )}
        <main>
            <article>
                <header class="post-title">
                    <h1>{title}</h1>
                    <div class="date">
                        <FormattedDate date={date} />
                        {updatedDate && (
                            <span class="last-updated">
                                updated <FormattedDate date={updatedDate} />
                            </span>
                        )}
                    </div>
                    {(tags && tags.length > 0) && (
                        <div class="meta">
                            {tags?.map((tag) => <a class="chip" href={`/tags/${tag}/`}>{tag}</a>)}
                        </div>
                    )}
                </header>
                <div class="prose">
                    <slot />
                </div>
                <Comments postId={id} />
            </article>
        </main>
        <Footer />
        <script>
            // Arriving from the landing page's "Continue reading" link
            // (#continue=N): jump to and briefly highlight the first block past
            // the excerpt. N is the exact cut the landing computed (it trims a
            // trailing heading), so the jump lands on real content or its heading.
            const m = location.hash.match(/^#continue(?:=(\d+))?$/);
            if (m) {
                const idx = m[1] ? Number(m[1]) : 3;
                requestAnimationFrame(() => {
                    const target = document.querySelectorAll('.prose > *')[idx];
                    if (target instanceof HTMLElement) {
                        // Only scroll if the passage is below the top two-thirds (or
                        // off-screen) - if it's already in view, don't jolt the page.
                        // When we do scroll, land it near the top, above the bottom third.
                        const rect = target.getBoundingClientRect();
                        const vh = window.innerHeight;
                        if (rect.top < 0 || rect.top > vh * (2 / 3)) {
                            window.scrollTo({ top: Math.max(0, window.scrollY + rect.top - vh * 0.22), behavior: 'smooth' });
                        }
                        // Slow, single highlight - long enough to catch the eye, no flashing.
                        target.animate(
                            [{ backgroundColor: 'rgba(224, 160, 80, 0.16)' }, { backgroundColor: 'rgba(224, 160, 80, 0)' }],
                            { duration: 3200, easing: 'ease-out' },
                        );
                    }
                });
            }
        </script>
    </body>
</html>
